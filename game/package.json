{
  "name": "survived-episode-x",
  "version": "0.1.0",
  "description": "反向 KPI 办公室生存模拟（像素风、回合制） — TS+PixiJS+Tauri",
  "type": "module",
  "private": true,
  "scripts": {
    "tsc": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "assets:sync": "node scripts/sync-sprites.mjs",
    "predev": "pnpm assets:sync",
    "prebuild": "pnpm assets:sync",
    "dev": "vite",
    "build": "vite build",
    "tauri": "tauri",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "verify": "pnpm assets:sync && pnpm tsc && pnpm lint && pnpm test"
  },
  "devDependencies": {
    "@biomejs/biome": "~1.9.4",
    "@tauri-apps/api": "~2.1.1",
    "@tauri-apps/cli": "~2.1.0",
    "@types/howler": "~2.2.12",
    "@types/node": "^25.6.0",
    "typescript": "~5.6.3",
    "vite": "~6.0.15",
    "vitest": "~2.1.9"
  },
  "dependencies": {
    "howler": "~2.2.4",
    "pixi.js": "~8.5.0",
    "preact": "~10.25.4"
  }
}
